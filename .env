# Server Configuration
PORT=3000
NODE_ENV=production

# Spotify OAuth
SPOTIFY_CLIENT_ID=20016a4c147a45d18cc0b3ba95726883
SPOTIFY_CLIENT_SECRET=your_client_secret_here
SPOTIFY_REDIRECT_URI=http://localhost:3000/callback

# Security
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.onrender.com

# Optional: Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
